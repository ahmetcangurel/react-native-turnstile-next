{
	"name": "react-native-turnstile-next",
	"version": "2.0.0",
	"description": "A React Native wrapper for Cloudflare Turnstile using react-native-webview.",
	"homepage": "https://github.com/ahmetcangurel/react-native-turnstile-next#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ahmetcangurel/react-native-turnstile-next.git"
	},
	"bugs": {
		"url": "https://github.com/ahmetcangurel/react-native-turnstile-next/issues"
	},
	"license": "MIT",
	"author": "Ahmet Can Gurel",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src --ext .ts,.tsx",
		"dev": "tsup src --format cjs,esm --watch",
		"prepack": "npm run build"
	},
	"files": [
		"dist/**/*.js*",
		"dist/**/*.mjs*",
		"dist/**/*.d*",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"keywords": [
		"cloudflare",
		"turnstile",
		"react-native",
		"react-native-webview",
		"captcha"
	],
	"peerDependencies": {
		"react": ">=18.0",
		"react-native": ">=0.74",
		"react-native-webview": ">=13.8.6"
	},
	"devDependencies": {
		"@babel/core": "^7.25.2",
		"@babel/preset-env": "^7.25.3",
		"@babel/runtime": "^7.25.0",
		"@react-native-community/eslint-config": "^3.2.0",
		"@tsconfig/react-native": "^3.0.5",
		"@types/jest": "^29.5.12",
		"@types/react": "^18.3.3",
		"@types/react-test-renderer": "^18.3.0",
		"babel-jest": "^29.7.0",
		"eslint": "^8.57.1",
		"jest": "^29.7.0",
		"metro-react-native-babel-preset": "^0.77.0",
		"prettier": "^2.8.8",
		"react": "18.2.0",
		"react-native": "^0.74.5",
		"react-native-webview": "^13.10.5",
		"react-test-renderer": "18.2.0",
		"tsup": "^8.2.4",
		"turnstile-types": "^1.2.1",
		"typescript": "^5.5.4"
	}
}
